<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.skillforge.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_home_to_courseDetail"
            app:destination="@id/courseDetailFragment" />
        <action
            android:id="@+id/action_home_to_categoryList"
            app:destination="@id/categoryListFragment" />
        <action
            android:id="@+id/action_home_to_courseList"
            app:destination="@id/courseListFragment" />
    </fragment>

    <fragment
        android:id="@+id/courseDetailFragment"
        android:name="com.example.skillforge.ui.coursedetail.CourseDetailFragment"
        android:label="Course Detail">
        <argument
            android:name="courseId"
            app:argType="string" />
        <action
            android:id="@+id/action_courseDetail_to_lesson"
            app:destination="@id/lessonFragment" />
    </fragment>

    <fragment
        android:id="@+id/lessonFragment"
        android:name="com.example.skillforge.ui.lesson.LessonFragment"
        android:label="Lesson">
        <argument
            android:name="courseId"
            app:argType="string" />
        <argument
            android:name="lessonId"
            app:argType="string" />
        <action
            android:id="@+id/action_lesson_to_lesson"
            app:destination="@id/lessonFragment"
            app:launchSingleTop="true"
            app:popUpTo="@id/lessonFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/categoryListFragment"
        android:name="com.example.skillforge.ui.categorylist.CategoryListFragment"
        android:label="Categories">
        <action
            android:id="@+id/action_categoryList_to_courseList"
            app:destination="@id/courseListFragment" />
    </fragment>

    <fragment
        android:id="@+id/courseListFragment"
        android:name="com.example.skillforge.ui.courselist.CourseListFragment"
        android:label="Courses">
        <argument
            android:name="categoryId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
        <action
            android:id="@+id/action_courseList_to_courseDetail"
            app:destination="@id/courseDetailFragment" />
    </fragment>
</navigation>
