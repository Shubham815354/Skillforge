<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/categories_header"
                android:textAppearance="@style/TextAppearance.Skillforge.TitleLarge" />

            <TextView
                android:id="@+id/seeAllCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp"
                android:text="@string/see_all"
                android:textAppearance="@style/TextAppearance.Skillforge.Label"
                android:textColor="@color/teal" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/categoriesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:clipToPadding="false"
            android:paddingHorizontal="20dp"
            tools:listitem="@layout/item_category_tile" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp">

            <ImageView
                android:id="@+id/scrollLeftButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_surface"
                android:clickable="true"
                android:contentDescription="@string/content_desc_scroll_left"
                android:focusable="true"
                android:padding="7dp"
                android:src="@drawable/ic_chevron_left" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_marginHorizontal="10dp"
                android:layout_weight="1">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_scrollbar_track" />

                <View
                    android:id="@+id/scrollThumb"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="start"
                    android:background="@drawable/bg_scrollbar_thumb" />
            </FrameLayout>

            <ImageView
                android:id="@+id/scrollRightButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_surface"
                android:clickable="true"
                android:contentDescription="@string/content_desc_scroll_right"
                android:focusable="true"
                android:padding="7dp"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>
    </LinearLayout>
</layout>
